# Arbitrum Sepolia RPC (if blocked by Cloudflare, try publicnode or Alchemy/Infura)
RPC_URL=https://arbitrum-sepolia-rpc.publicnode.com
# RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Contract addresses (match frontend/.env on Vercel / local)
ENGINE_ADDRESS=0x0348E674020edf3E90BD0F791DeCebe6EbD620b8
MOCK_WSTETH_ADDRESS=0x843989F6D1616812CDa58f54D8f8A37498e67FE3
WSTETH_VAULT=0x6E829cFaA1cEAD52C76f27902517FBe8d22EFD2A
CEITUSD_ADDRESS=0x29E3fee667D8ef595670F5086C6EDE567473fC87

# Market id for wstETH (usually 0)
MARKET_ID=0

# Optional: ping production app (analytics only, not on-chain)
APP_URL=https://www.ceitnot.io

# One private key per line in wallets.txt OR comma-separated here (never commit real keys)
# PRIVATE_KEYS=0xabc...,0xdef...

# Amounts (18 decimals)
WSTETH_MINT=1000000000000000000
BORROW_AMOUNT=50000000000000000000
REPAY_AMOUNT=25000000000000000000

# Delay between txs for same wallet (ms). Arbitrum Sepolia ~2s/block; use >= 3000
TX_DELAY_MS=4000
# Delay between wallets (ms)
WALLET_DELAY_MS=8000

# Auto-fund workers with Sepolia ETH (default on). Needs one funded wallet.
# Option A: dedicated funder (recommended) — fund once via faucet, then bot sends to others
FUNDER_PRIVATE_KEY=0x...
# Option B: leave FUNDER empty — bot uses the richest key in wallets.txt as funder

AUTO_FUND=1
MIN_ETH_BALANCE=0.003
TOP_UP_ETH=0.008
