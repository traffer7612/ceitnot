# Aura Protocol Frontend — Environment Variables
# Copy this file to .env and fill in your values.

# ── Contract Addresses (required for on-chain reads/writes) ──────────────────
# AuraEngine proxy address
VITE_ENGINE_ADDRESS=0x0000000000000000000000000000000000000000

# AuraMarketRegistry address
VITE_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000

# ── Chain (optional — defaults to Anvil/Foundry localhost) ───────────────────
# VITE_CHAIN_ID=31337

# ── WalletConnect (optional — required for WalletConnect v2 support) ─────────
# Get a free project ID at https://cloud.walletconnect.com
# VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here
