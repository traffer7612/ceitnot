PORT=3001
# Optional: engine address for stats and frontend config
AURA_ENGINE_ADDRESS=0x0000000000000000000000000000000000000000
# AURA_VAULT_4626_ADDRESS=0x...
# Optional: custom RPC for stats (default: chain default RPC)
# RPC_URL=https://arb1.arbitrum.io/rpc

# Faucet (for local Anvil): first Anvil account key — sends 0.5 ETH to requested address
# FAUCET_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# FAUCET_RPC_URL=http://127.0.0.1:8545

# AURA faucet (testnet): POST /api/faucet/aura mints 1000 AURA to the requested address.
# Copy to backend/.env and set (never commit .env). Key = minter private key with 0x prefix.
#
# Где взять AURA_TOKEN_ADDRESS:
# 1) Запустите деплой: forge script script/DeployFullSepolia.s.sol:DeployFullSepolia --rpc-url <sepolia-rpc> --broadcast --private-key <key>
# 2) В выводе в терминале найдите строку "AURA_TOKEN:         0x..." — скопируйте этот адрес (0x...).
# 3) Либо откройте broadcast/DeployFullSepolia.s.sol/11155111/run-<timestamp>.json и в transactions найдите запись с "contractName": "AuraToken" → contractAddress.
#
# FAUCET_PRIVATE_KEY=0x...
# AURA_TOKEN_ADDRESS=0x...
